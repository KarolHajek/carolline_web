---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_TITLE, SITE_URL } from '../consts';
import { buildBreadcrumbJsonLd, getFeaturedReferences, getFeaturedServices, getSiteSettings, sortByTitle } from '../lib/content';

const settings = await getSiteSettings();
const services = await getFeaturedServices();
const references = await getFeaturedReferences();
const productLines = await getCollection('productLines');
const brands = sortByTitle(await getCollection('brands'));

const heroImage = 'https://carolline.sk/wp-content/uploads/2025/05/car-wrapping-with-foil-car-service.jpg';
const workshopImage = 'https://carolline.sk/wp-content/uploads/2025/03/avery-instalacia-folii.png';
const fleetImage = 'https://carolline.sk/wp-content/uploads/2025/05/reklamny-polep-resort.jpeg';

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: settings.company.name,
		url: SITE_URL,
		email: settings.company.email,
		telephone: settings.company.phone,
		address: {
			'@type': 'PostalAddress',
			streetAddress: settings.company.primaryAddress.street,
			postalCode: settings.company.primaryAddress.postalCode,
			addressLocality: settings.company.primaryAddress.city,
			addressCountry: 'SK',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'LocalBusiness',
		name: settings.company.name,
		url: SITE_URL,
		description: 'B2B partner pre fólie, technické produkty a realizačné služby.',
		email: settings.company.email,
		telephone: settings.company.phone,
		openingHours: 'Mo-Fr 08:00-16:30',
	},
	buildBreadcrumbJsonLd([{ name: 'Domov', item: SITE_URL }]),
];
---

<MainLayout title={SITE_TITLE} description="CLG je B2B partner pre Avery fólie, 3M technické produkty, značenie vozidiel a profesionálnu realizáciu polepov." structuredData={structuredData}>
	<section class="hero" style={`--hero-image: url('${heroImage}')`}>
		<div class="shell hero-content">
			<p class="eyebrow">Carol line Group</p>
			<h1>CLG</h1>
			<p class="hero-title">B2B partner pre fólie, technické produkty a profesionálnu aplikáciu.</p>
			<p class="hero-lead">
				Dodávame Avery materiály pre print a wrap, 3M technické produkty, štítky a lepidlá. Zároveň realizujeme
				reklamné polepy, značenie vozidiel, autofólie, ochranu laku a fólie na budovy.
			</p>
			<div class="hero-actions">
				<a class="button" href="/kontakt/?typ=material">Dopyt na materiály</a>
				<a class="button-secondary" href="/kontakt/?typ=realizacia">Dopyt na realizáciu</a>
			</div>
		</div>
	</section>

	<section class="shell trust-bar" aria-label="Značky a dôveryhodnosť">
		{settings.trustBadges.map((badge) => <span>{badge}</span>)}
	</section>

	<section class="shell intro">
		<div>
			<p class="eyebrow">Čo robíme</p>
			<h2>Materiál aj realizácia v jednom zodpovednom procese.</h2>
		</div>
		<p>
			Carolline dnes nie je len firma na polepy. Web staviame ako B2B prezentáciu pre firmy, fleet klientov,
			technické prevádzky a partnerov, ktorí potrebujú spoľahlivý materiál, odborné odporúčanie a výsledok, ktorý
			vydrží reálnu prevádzku.
		</p>
	</section>

	<section class="shell capability-grid">
		<article>
			<span>01</span>
			<h3>Distribúcia materiálov</h3>
			<p>Avery Dennison fólie pre wrap, print, branding a solárne aplikácie. Výber podľa účelu, podkladu a očakávanej životnosti.</p>
		</article>
		<article>
			<span>02</span>
			<h3>3M technické produkty</h3>
			<p>Štítky, lepidlá a funkčné materiály pre označovanie, výrobu, servis a technické B2B zadania.</p>
		</article>
		<article>
			<span>03</span>
			<h3>Aplikácia a montáž</h3>
			<p>Polepy vozidiel, značenie, car wrap, autofólie, ochrana laku a fólie na budovy od skúseného realizačného tímu.</p>
		</article>
	</section>

	<section class="visual-proof">
		<div class="shell visual-grid">
			<img class="visual-large" src={workshopImage} alt="Aplikácia fólie v dielni CLG" loading="lazy" />
			<img src={fleetImage} alt="Reklamný polep vozidla" loading="lazy" />
			<div class="visual-note">
				<p class="eyebrow">Praktické riešenia</p>
				<h2>Od bezpečnosti cez reklamu až po komfort.</h2>
				<p>
					Aktuálny obsah z carolline.sk zachovávame, ale upratujeme ho do jasnej firemnej logiky: materiály,
					realizácie a služby pre opakované B2B zadania.
				</p>
			</div>
		</div>
	</section>

	<section class="shell products">
		<div class="section-head">
			<div>
				<p class="eyebrow">Fólie a materiály</p>
				<h2>Katalóg bez e-shopového šumu</h2>
			</div>
			<a class="text-link" href="/folie-materialy/">Všetky produktové línie</a>
		</div>
		<div class="product-list">
			{
				productLines.map((line, index) => (
					<a href="/folie-materialy/">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<div>
							<h3>{line.data.title}</h3>
							<p>{line.data.description}</p>
						</div>
						<strong>{line.data.featuredBrands.join(' / ')}</strong>
					</a>
				))
			}
		</div>
	</section>

	<section class="services">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Realizačné služby</p>
					<h2>Pre vozidlá, flotily, budovy a prevádzky</h2>
				</div>
				<a class="text-link" href="/sluzby/">Prehľad služieb</a>
			</div>
			<div class="service-grid">
				{
					services.map((service) => (
						<a class="service-card" href={`/${service.data.slug}/`}>
							<img src={service.data.heroImage} alt={service.data.title} loading="lazy" />
							<div>
								<span>{service.data.shortTitle ?? service.data.title}</span>
								<h3>{service.data.title}</h3>
								<p>{service.data.description}</p>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="shell brands">
		<div class="brand-copy">
			<p class="eyebrow">Značky</p>
			<h2>Silné portfólio potrebuje správne odporúčanie.</h2>
			<p>
				Značky ako 3M a Avery Dennison dávajú najväčší zmysel vtedy, keď sú správne zvolené pre konkrétny
				podklad, expozíciu a spôsob používania.
			</p>
		</div>
		<div class="brand-list">
			{
				brands.map((brand) => (
					<a href={`/znacky/${brand.data.slug}/`}>
						<span>{brand.data.logoLabel}</span>
						<h3>{brand.data.title}</h3>
						<p>{brand.data.description}</p>
					</a>
				))
			}
		</div>
	</section>

	<section class="shell references">
		<div class="section-head">
			<div>
				<p class="eyebrow">Realizácie</p>
				<h2>Ukážky práce v prevádzke</h2>
			</div>
			<a class="text-link" href="/realizacie/">Všetky realizácie</a>
		</div>
		<div class="reference-grid">
			{
				references.map((reference) => (
					<article>
						<img src={reference.data.image} alt={reference.data.title} loading="lazy" />
						<div>
							<span>{reference.data.category}</span>
							<h3>{reference.data.title}</h3>
							<p>{reference.data.description}</p>
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="cta">
		<div class="shell cta-inner">
			<div>
				<p class="eyebrow">Dopyt a konzultácia</p>
				<h2>Pošlite zadanie. Navrhneme vhodný materiál alebo realizáciu.</h2>
			</div>
			<div class="cta-actions">
				<a class="button" href="/kontakt/?typ=material">Potrebujem materiál</a>
				<a class="button-secondary" href="/kontakt/?typ=realizacia">Potrebujem realizáciu</a>
			</div>
		</div>
	</section>
</MainLayout>

<style>
	.hero {
		min-height: 620px;
		display: flex;
		align-items: center;
		background:
			linear-gradient(90deg, rgba(244, 247, 248, 0.96) 0%, rgba(244, 247, 248, 0.86) 43%, rgba(244, 247, 248, 0.24) 78%),
			var(--hero-image) center right / cover;
		border-bottom: 1px solid var(--color-border);
	}

	.hero-content {
		padding-block: 4.8rem 3rem;
	}

	.hero-content h1 {
		margin-bottom: 0.55rem;
		font-size: 5rem;
		line-height: 0.92;
	}

	.hero-title {
		max-width: 650px;
		color: var(--color-text);
		font-family: var(--font-heading);
		font-size: 2rem;
		font-style: italic;
		font-weight: 700;
		line-height: 1.12;
		text-transform: uppercase;
	}

	.hero-lead {
		max-width: 620px;
		margin-top: 1.1rem;
		color: var(--color-muted-strong);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}

	.trust-bar {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		margin-top: 1.5rem;
		background: #fff;
		border: 1px solid var(--color-border);
	}

	.trust-bar span {
		padding: 0.95rem 0.7rem;
		border-right: 1px solid var(--color-border);
		color: var(--color-muted-strong);
		font-size: 0.82rem;
		font-weight: 800;
		text-align: center;
	}

	.trust-bar span:last-child {
		border-right: 0;
	}

	.intro,
	.capability-grid,
	.products,
	.brands,
	.references {
		padding-block: 4.5rem;
	}

	.intro {
		display: grid;
		grid-template-columns: 0.9fr 1fr;
		gap: 3rem;
		align-items: end;
	}

	.intro > p {
		color: var(--color-muted-strong);
		font-size: 1.06rem;
	}

	.capability-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		padding-top: 0;
	}

	.capability-grid article,
	.brand-list a,
	.reference-grid article {
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-card);
	}

	.capability-grid article {
		padding: 1.4rem;
	}

	.capability-grid span,
	.product-list span,
	.service-card span,
	.brand-list span,
	.reference-grid span {
		display: block;
		margin-bottom: 0.55rem;
		color: var(--color-accent);
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.capability-grid h3 {
		margin-bottom: 0.65rem;
	}

	.visual-proof {
		padding-block: 3rem;
		background: #fff;
		border-block: 1px solid var(--color-border);
	}

	.visual-grid {
		display: grid;
		grid-template-columns: 1.1fr 0.8fr 0.9fr;
		gap: 1rem;
		align-items: stretch;
	}

	.visual-grid img,
	.visual-note {
		min-height: 330px;
		border-radius: var(--radius-lg);
	}

	.visual-grid img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.visual-large {
		grid-row: span 2;
	}

	.visual-note {
		display: grid;
		align-content: center;
		padding: 2rem;
		background: var(--color-panel-strong);
	}

	.visual-note h2,
	.visual-note p {
		color: #fff;
	}

	.visual-note p:last-child {
		margin-top: 1rem;
		color: rgba(255, 255, 255, 0.76);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		align-items: end;
		margin-bottom: 1.5rem;
	}

	.text-link {
		color: var(--color-text);
		font-size: 0.86rem;
		font-weight: 850;
		text-transform: uppercase;
		text-decoration: none;
	}

	.product-list {
		display: grid;
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
	}

	.product-list a {
		display: grid;
		grid-template-columns: 56px minmax(0, 1fr) 180px;
		gap: 1.2rem;
		align-items: start;
		padding: 1.15rem;
		border-bottom: 1px solid var(--color-border);
		color: inherit;
		text-decoration: none;
	}

	.product-list a:last-child {
		border-bottom: 0;
	}

	.product-list h3 {
		margin-bottom: 0.35rem;
	}

	.product-list strong {
		color: var(--color-muted-strong);
		font-size: 0.88rem;
		text-align: right;
	}

	.services {
		padding-block: 4.5rem;
		background: #eaf0f2;
		border-block: 1px solid var(--color-border);
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.service-card {
		display: grid;
		grid-template-rows: 170px 1fr;
		overflow: hidden;
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		color: inherit;
		text-decoration: none;
		box-shadow: var(--shadow-card);
	}

	.service-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.service-card div {
		padding: 1rem;
	}

	.service-card h3 {
		margin-bottom: 0.5rem;
	}

	.service-card p {
		font-size: 0.9rem;
	}

	.brands {
		display: grid;
		grid-template-columns: 0.8fr 1fr;
		gap: 2rem;
		align-items: start;
	}

	.brand-copy p:last-child {
		margin-top: 1rem;
		color: var(--color-muted-strong);
	}

	.brand-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.brand-list a {
		display: grid;
		gap: 0.55rem;
		padding: 1.25rem;
		color: inherit;
		text-decoration: none;
	}

	.reference-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.reference-grid article {
		overflow: hidden;
	}

	.reference-grid img {
		width: 100%;
		height: 190px;
		object-fit: cover;
	}

	.reference-grid div {
		padding: 1rem;
	}

	.reference-grid h3 {
		margin-bottom: 0.5rem;
	}

	.cta {
		padding-block: 4rem;
		background: var(--color-panel-strong);
	}

	.cta-inner {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		align-items: center;
	}

	.cta h2 {
		max-width: 680px;
		color: #fff;
	}

	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: flex-end;
	}

	.cta .button-secondary {
		border-color: rgba(255, 255, 255, 0.32);
		background: transparent;
		color: #fff;
	}

	@media (max-width: 980px) {
		.hero {
			min-height: 560px;
		}

		.hero-content h1 {
			font-size: 4rem;
		}

		.hero-title {
			font-size: 1.55rem;
		}

		.trust-bar,
		.intro,
		.visual-grid,
		.brands,
		.reference-grid,
		.service-grid {
			grid-template-columns: 1fr 1fr;
		}

		.capability-grid {
			grid-template-columns: 1fr;
		}

		.product-list a {
			grid-template-columns: 44px 1fr;
		}

		.product-list strong {
			grid-column: 2;
			text-align: left;
		}

		.cta-inner,
		.section-head {
			display: grid;
		}

		.cta-actions {
			justify-content: flex-start;
		}
	}

	@media (max-width: 640px) {
		.hero {
			min-height: auto;
			padding-block: 2rem;
			background:
				linear-gradient(180deg, rgba(244, 247, 248, 0.97), rgba(244, 247, 248, 0.82)),
				var(--hero-image) center / cover;
		}

		.hero-content {
			padding-block: 3rem 1rem;
		}

		.hero-content h1 {
			font-size: 3.2rem;
		}

		.hero-title {
			font-size: 1.28rem;
		}

		.trust-bar,
		.intro,
		.visual-grid,
		.service-grid,
		.brands,
		.brand-list,
		.reference-grid {
			grid-template-columns: 1fr;
		}

		.visual-grid img,
		.visual-note {
			min-height: 230px;
		}

		.intro,
		.capability-grid,
		.products,
		.brands,
		.references,
		.services {
			padding-block: 3rem;
		}
	}
</style>
