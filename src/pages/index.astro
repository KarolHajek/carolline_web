---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_TITLE, SITE_URL } from '../consts';
import { buildBreadcrumbJsonLd, getFeaturedReferences, getFeaturedServices, getSiteSettings, sortByTitle } from '../lib/content';

const settings = await getSiteSettings();
const services = await getFeaturedServices();
const references = await getFeaturedReferences();
const productLines = await getCollection('productLines');
const brands = sortByTitle(await getCollection('brands'));

const heroImage = 'https://carolline.sk/wp-content/uploads/2025/05/car-wrapping-with-foil-car-service.jpg';
const workshopImage = 'https://carolline.sk/wp-content/uploads/2025/03/avery-instalacia-folii.png';
const fleetImage = 'https://carolline.sk/wp-content/uploads/2025/05/reklamny-polep-resort.jpeg';
const tintImage = 'https://carolline.sk/wp-content/uploads/2025/03/avery-solarne-folie.png';

const proofPoints = [
	{ value: 'B2B', label: 'materiály, technické riešenia a realizácie' },
	{ value: '3M', label: 'štítky, lepidlá a funkčné produkty' },
	{ value: 'Avery', label: 'wrap, print a fólie pre profesionálne použitie' },
];

const processSteps = [
	{
		title: 'Zadanie a účel',
		text: 'Najprv si ujasníme podklad, spôsob používania, expozíciu a obchodný cieľ.',
	},
	{
		title: 'Výber materiálu',
		text: 'Odporučíme fóliu, technický produkt alebo kombináciu riešení podľa reálnej prevádzky.',
	},
	{
		title: 'Dopyt alebo realizácia',
		text: 'Dodáme materiál partnerovi alebo zabezpečíme kompletnú aplikáciu v našej réžii.',
	},
	{
		title: 'Výsledok v prevádzke',
		text: 'Riešenie má byť čitateľné, trvácne a servisovateľné, nie iba pekné v deň odovzdania.',
	},
];

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: settings.company.name,
		url: SITE_URL,
		email: settings.company.email,
		telephone: settings.company.phone,
		address: {
			'@type': 'PostalAddress',
			streetAddress: settings.company.primaryAddress.street,
			postalCode: settings.company.primaryAddress.postalCode,
			addressLocality: settings.company.primaryAddress.city,
			addressCountry: 'SK',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'LocalBusiness',
		name: settings.company.name,
		url: SITE_URL,
		description: 'B2B partner pre fólie, technické produkty a realizačné služby.',
		email: settings.company.email,
		telephone: settings.company.phone,
		openingHours: 'Mo-Fr 08:00-16:30',
	},
	buildBreadcrumbJsonLd([{ name: 'Domov', item: SITE_URL }]),
];
---

<MainLayout title={SITE_TITLE} description="CLG je B2B partner pre Avery fólie, 3M technické produkty, značenie vozidiel a profesionálnu realizáciu polepov." structuredData={structuredData}>
	<section class="hero">
		<div class="shell hero-grid">
			<div class="hero-copy">
				<p class="eyebrow">Carol line Group / CLG</p>
				<h1>B2B partner pre fólie, technické produkty a aplikáciu.</h1>
				<p class="hero-lead">
					Dodávame Avery materiály pre print a wrap, 3M štítky, lepidlá a technické produkty. Zároveň realizujeme
					polepy, značenie vozidiel, car wrap, autofólie, ochranu laku a fólie na budovy.
				</p>
				<div class="hero-actions">
					<a class="button" href="/kontakt/?typ=material">Dopyt na materiály</a>
					<a class="button-secondary" href="/kontakt/?typ=realizacia">Dopyt na realizáciu</a>
				</div>
			</div>
			<div class="hero-media" aria-label="Ukážka realizácie CLG">
				<img src={heroImage} alt="Profesionálna aplikácia fólie na vozidlo" />
				<div class="hero-panel">
					<span>Materiál + montáž</span>
					<strong>Jedna zodpovednosť od odporúčania po výsledok.</strong>
				</div>
			</div>
		</div>
	</section>

	<section class="shell trust-strip" aria-label="Značky a dôveryhodnosť">
		{settings.trustBadges.map((badge) => <span>{badge}</span>)}
	</section>

	<section class="shell proof-grid" aria-label="Hlavné oblasti CLG">
		{
			proofPoints.map((point) => (
				<article>
					<strong>{point.value}</strong>
					<p>{point.label}</p>
				</article>
			))
		}
	</section>

	<section class="shell intro-section">
		<div class="section-kicker">
			<p class="eyebrow">Profilácia</p>
			<h2>Nie iba servis polepov. Firemný partner pre materiály aj realizáciu.</h2>
		</div>
		<p>
			Nový web staviame viac B2B: pre firmy, fleet klientov, reklamné agentúry, prevádzky a organizácie, ktoré
			potrebujú spoľahlivý materiál, technické odporúčanie a kvalitnú aplikáciu. Obsah zo starej stránky zachováme,
			ale usporiadame ho tak, aby bolo hneď jasné, s čím vie CLG obchodne pomôcť.
		</p>
	</section>

	<section class="shell capability-section">
		<article class="capability-card featured-card">
			<span>01</span>
			<h3>Distribúcia fólií a materiálov</h3>
			<p>
				Avery Dennison fólie pre wrap, print, flotilové brandingy, reklamné polepy a funkčné aplikácie na vozidlách
				aj budovách.
			</p>
			<a href="/folie-materialy/">Pozrieť materiály</a>
		</article>
		<article class="capability-card">
			<span>02</span>
			<h3>3M technické produkty</h3>
			<p>
				Štítky, lepidlá a technické produkty pre označovanie, výrobu, servis, bezpečnosť a špecifické B2B použitie.
			</p>
			<a href="/znacky/3m/">3M portfólio</a>
		</article>
		<article class="capability-card">
			<span>03</span>
			<h3>Realizačné služby</h3>
			<p>
				Aplikácia fólií, marketingové polepy, car wrap, ochrana laku, autofólie, fólie na budovy a značenie vozidiel.
			</p>
			<a href="/sluzby/">Služby CLG</a>
		</article>
	</section>

	<section class="showcase">
		<div class="shell showcase-grid">
			<div class="showcase-copy">
				<p class="eyebrow">Firemné zadania</p>
				<h2>Od výberu materiálu po viditeľný výsledok v prevádzke.</h2>
				<p>
					CLG má výhodu v tom, že rozumie obom stranám zadania: materiálu aj aplikácii. Pri B2B projektoch to
					znamená menej improvizácie, presnejšie odporúčania a lepšiu kontrolu výsledku.
				</p>
			</div>
			<div class="showcase-images">
				<img class="wide" src={workshopImage} alt="Aplikácia Avery fólie v dielni CLG" loading="lazy" />
				<img src={fleetImage} alt="Reklamný polep firemného vozidla" loading="lazy" />
				<img src={tintImage} alt="Solárna fólia na vozidle" loading="lazy" />
			</div>
		</div>
	</section>

	<section class="shell catalogue-section">
		<div class="section-head">
			<div>
				<p class="eyebrow">Katalógový vstup</p>
				<h2>Produktové línie bez e-shopového šumu</h2>
			</div>
			<a class="text-link" href="/folie-materialy/">Všetky materiály</a>
		</div>
		<div class="catalogue-grid">
			{
				productLines.map((line, index) => (
					<a class="catalogue-card" href="/folie-materialy/">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<h3>{line.data.title}</h3>
						<p>{line.data.description}</p>
						<strong>{line.data.featuredBrands.join(' / ')}</strong>
					</a>
				))
			}
		</div>
	</section>

	<section class="services-section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Realizácia</p>
					<h2>Služby pre vozidlá, flotily, budovy a prevádzky</h2>
				</div>
				<a class="text-link" href="/sluzby/">Prehľad služieb</a>
			</div>
			<div class="service-grid">
				{
					services.map((service) => (
						<a class="service-card" href={`/${service.data.slug}/`}>
							<img src={service.data.heroImage} alt={service.data.title} loading="lazy" />
							<div>
								<span>{service.data.shortTitle ?? service.data.title}</span>
								<h3>{service.data.title}</h3>
								<p>{service.data.description}</p>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="shell brands-section">
		<div class="section-kicker">
			<p class="eyebrow">Značky</p>
			<h2>Silné portfólio funguje až vtedy, keď je správne zvolené.</h2>
		</div>
		<div class="brand-grid">
			{
				brands.map((brand) => (
					<a href={`/znacky/${brand.data.slug}/`}>
						<span>{brand.data.logoLabel}</span>
						<h3>{brand.data.title}</h3>
						<p>{brand.data.description}</p>
					</a>
				))
			}
		</div>
	</section>

	<section class="process-section">
		<div class="shell process-grid">
			<div>
				<p class="eyebrow">Ako spolupracujeme</p>
				<h2>Jednoduchý proces pre nákup aj realizáciu.</h2>
			</div>
			<div class="process-list">
				{
					processSteps.map((step, index) => (
						<article>
							<span>{String(index + 1).padStart(2, '0')}</span>
							<div>
								<h3>{step.title}</h3>
								<p>{step.text}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="shell references-section">
		<div class="section-head">
			<div>
				<p class="eyebrow">Realizácie</p>
				<h2>Ukážky práce v reálnej prevádzke</h2>
			</div>
			<a class="text-link" href="/realizacie/">Všetky realizácie</a>
		</div>
		<div class="reference-grid">
			{
				references.map((reference) => (
					<article>
						<img src={reference.data.image} alt={reference.data.title} loading="lazy" />
						<div>
							<span>{reference.data.category}</span>
							<h3>{reference.data.title}</h3>
							<p>{reference.data.description}</p>
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="cta-section">
		<div class="shell cta-inner">
			<div>
				<p class="eyebrow">Dopyt a konzultácia</p>
				<h2>Pošlite zadanie. Navrhneme vhodný materiál alebo kompletnú realizáciu.</h2>
			</div>
			<div class="cta-actions">
				<a class="button" href="/kontakt/?typ=material">Potrebujem materiál</a>
				<a class="button-secondary" href="/kontakt/?typ=realizacia">Potrebujem realizáciu</a>
			</div>
		</div>
	</section>
</MainLayout>

<style is:global>
	.hero {
		overflow: hidden;
		padding-block: 5.4rem 3.6rem;
		background:
			radial-gradient(circle at 18% 12%, rgba(0, 183, 225, 0.16), transparent 30rem),
			linear-gradient(135deg, #f8fbfc 0%, #edf3f5 100%);
		border-bottom: 1px solid var(--color-border);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(360px, 0.8fr);
		gap: clamp(2rem, 5vw, 4.5rem);
		align-items: center;
	}

	.hero-copy h1 {
		max-width: 760px;
		font-size: clamp(2.45rem, 5vw, 4.65rem);
		letter-spacing: -0.04em;
	}

	.hero-lead {
		max-width: 680px;
		margin-top: 1.25rem;
		color: var(--color-muted-strong);
		font-size: 1.06rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.6rem;
	}

	.hero-media {
		position: relative;
		min-height: 520px;
	}

	.hero-media::before,
	.hero-media::after {
		content: '';
		position: absolute;
		border-radius: 999px;
		background: var(--color-accent);
		opacity: 0.16;
		filter: blur(10px);
	}

	.hero-media::before {
		top: 1.2rem;
		right: -1rem;
		width: 10rem;
		height: 10rem;
	}

	.hero-media::after {
		bottom: 2rem;
		left: -2rem;
		width: 7rem;
		height: 7rem;
	}

	.hero-media img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border: 1px solid rgba(26, 29, 33, 0.12);
		border-radius: var(--radius-lg);
		box-shadow: 0 24px 70px rgba(26, 29, 33, 0.16);
	}

	.hero-panel {
		position: absolute;
		right: 1.2rem;
		bottom: 1.2rem;
		max-width: 310px;
		padding: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.42);
		border-radius: var(--radius-md);
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(16px);
	}

	.hero-panel span,
	.capability-card span,
	.catalogue-card span,
	.service-card span,
	.brand-grid span,
	.process-list span,
	.reference-grid span {
		display: block;
		margin-bottom: 0.55rem;
		color: var(--color-accent);
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.hero-panel strong {
		display: block;
		color: var(--color-text);
		font-family: var(--font-heading);
		font-style: italic;
		line-height: 1.15;
		text-transform: uppercase;
	}

	.trust-strip {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		margin-top: -1.2rem;
		overflow: hidden;
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-card);
	}

	.trust-strip span {
		padding: 0.95rem 0.7rem;
		border-right: 1px solid var(--color-border);
		color: var(--color-muted-strong);
		font-size: 0.8rem;
		font-weight: 850;
		text-align: center;
	}

	.trust-strip span:last-child {
		border-right: 0;
	}

	.proof-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		padding-block: 3rem 1rem;
	}

	.proof-grid article {
		padding: 1.35rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #fff;
	}

	.proof-grid strong {
		display: block;
		margin-bottom: 0.35rem;
		color: var(--color-text);
		font-family: var(--font-heading);
		font-size: 1.6rem;
		font-style: italic;
		line-height: 1;
		text-transform: uppercase;
	}

	.intro-section,
	.catalogue-section,
	.brands-section,
	.references-section {
		padding-block: 4.3rem;
	}

	.intro-section {
		display: grid;
		grid-template-columns: 0.9fr 1fr;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: end;
	}

	.intro-section > p {
		color: var(--color-muted-strong);
		font-size: 1.02rem;
	}

	.section-kicker {
		max-width: 720px;
	}

	.capability-section {
		display: grid;
		grid-template-columns: 1.2fr 1fr 1fr;
		gap: 1rem;
		padding-bottom: 4.6rem;
	}

	.capability-card,
	.catalogue-card,
	.brand-grid a,
	.reference-grid article {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #fff;
		box-shadow: var(--shadow-card);
	}

	.capability-card {
		display: grid;
		align-content: start;
		min-height: 250px;
		padding: 1.35rem;
	}

	.capability-card.featured-card {
		background:
			linear-gradient(135deg, rgba(0, 183, 225, 0.14), transparent 52%),
			#fff;
	}

	.capability-card h3,
	.catalogue-card h3,
	.service-card h3,
	.brand-grid h3,
	.process-list h3,
	.reference-grid h3 {
		margin-bottom: 0.55rem;
	}

	.capability-card a {
		align-self: end;
		margin-top: 1.2rem;
		color: var(--color-text);
		font-size: 0.82rem;
		font-weight: 850;
		text-transform: uppercase;
		text-decoration: none;
	}

	.showcase {
		padding-block: 4.4rem;
		background: #fff;
		border-block: 1px solid var(--color-border);
	}

	.showcase-grid {
		display: grid;
		grid-template-columns: 0.78fr 1.22fr;
		gap: 2rem;
		align-items: center;
	}

	.showcase-copy p:last-child {
		margin-top: 1rem;
		color: var(--color-muted-strong);
	}

	.showcase-images {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 0.85rem;
	}

	.showcase-images img {
		width: 100%;
		height: 250px;
		object-fit: cover;
		border-radius: var(--radius-md);
	}

	.showcase-images .wide {
		grid-row: span 2;
		height: 100%;
		min-height: 520px;
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		align-items: end;
		margin-bottom: 1.4rem;
	}

	.text-link {
		color: var(--color-text);
		font-size: 0.82rem;
		font-weight: 850;
		text-transform: uppercase;
		text-decoration: none;
	}

	.catalogue-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.catalogue-card {
		display: grid;
		padding: 1.35rem;
		color: inherit;
		text-decoration: none;
	}

	.catalogue-card strong {
		margin-top: 1.1rem;
		color: var(--color-muted-strong);
		font-size: 0.82rem;
	}

	.services-section {
		padding-block: 4.4rem;
		background: #eaf0f2;
		border-block: 1px solid var(--color-border);
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.service-card {
		display: grid;
		grid-template-rows: 150px 1fr;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #fff;
		color: inherit;
		text-decoration: none;
		box-shadow: var(--shadow-card);
	}

	.service-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.service-card div {
		padding: 1rem;
	}

	.service-card p {
		font-size: 0.9rem;
	}

	.brands-section {
		display: grid;
		grid-template-columns: 0.85fr 1.15fr;
		gap: 2rem;
		align-items: start;
	}

	.brand-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.brand-grid a {
		padding: 1.25rem;
		color: inherit;
		text-decoration: none;
	}

	.process-section {
		padding-block: 4.4rem;
		background: #fff;
		border-block: 1px solid var(--color-border);
	}

	.process-grid {
		display: grid;
		grid-template-columns: 0.8fr 1.2fr;
		gap: 2rem;
	}

	.process-list {
		display: grid;
		gap: 0.8rem;
	}

	.process-list article {
		display: grid;
		grid-template-columns: 64px 1fr;
		gap: 1rem;
		padding: 1.05rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #f8fbfc;
	}

	.reference-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.reference-grid article {
		overflow: hidden;
	}

	.reference-grid img {
		width: 100%;
		height: 185px;
		object-fit: cover;
		object-position: center bottom;
	}

	.reference-grid div {
		padding: 1rem;
	}

	.reference-grid p {
		font-size: 0.92rem;
	}

	.cta-section {
		padding-block: 4.4rem;
		background:
			linear-gradient(135deg, rgba(0, 183, 225, 0.18), transparent 45%),
			var(--color-panel-strong);
	}

	.cta-inner {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		align-items: center;
	}

	.cta-section h2 {
		max-width: 760px;
		color: #fff;
	}

	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: flex-end;
	}

