---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_TITLE, SITE_URL } from '../consts';
import { buildBreadcrumbJsonLd, getFeaturedReferences, getFeaturedServices, getSiteSettings, sortByTitle } from '../lib/content';

const settings = await getSiteSettings();
const services = await getFeaturedServices();
const references = await getFeaturedReferences();
const productLines = await getCollection('productLines');
const brands = sortByTitle(await getCollection('brands'));

const heroImage = 'https://carolline.sk/wp-content/uploads/2025/05/car-wrapping-with-foil-car-service.jpg';
const workshopImage = 'https://carolline.sk/wp-content/uploads/2025/03/avery-instalacia-folii.png';
const fleetImage = 'https://carolline.sk/wp-content/uploads/2025/05/reklamny-polep-resort.jpeg';
const filmImage = 'https://carolline.sk/wp-content/uploads/2025/03/autofolie-solarnefolie-ukazka-2.jpeg';

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: settings.company.name,
		url: SITE_URL,
		email: settings.company.email,
		telephone: settings.company.phone,
		address: {
			'@type': 'PostalAddress',
			streetAddress: settings.company.primaryAddress.street,
			postalCode: settings.company.primaryAddress.postalCode,
			addressLocality: settings.company.primaryAddress.city,
			addressCountry: 'SK',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'LocalBusiness',
		name: settings.company.name,
		url: SITE_URL,
		description: 'B2B partner pre fólie, technické produkty a realizačné služby.',
		email: settings.company.email,
		telephone: settings.company.phone,
		openingHours: 'Mo-Fr 08:00-16:30',
	},
	buildBreadcrumbJsonLd([{ name: 'Domov', item: SITE_URL }]),
];
---

<MainLayout title={SITE_TITLE} description="CLG je B2B partner pre Avery fólie, 3M technické produkty, značenie vozidiel a profesionálnu realizáciu polepov." structuredData={structuredData}>
	<section class="landing-hero" style={`--hero-image: url('${heroImage}')`}>
		<div class="shell hero-inner">
			<div class="hero-copy">
				<p class="eyebrow">B2B distribúcia a realizácia</p>
				<h1>CLG</h1>
				<p class="hero-subtitle">Fólie, technické produkty a profesionálne aplikácie pre firemnú prevádzku.</p>
				<p class="hero-lead">
					Dodávame Avery materiály pre print a wrap, 3M technické produkty, štítky a lepidlá. Zároveň
					realizujeme polepy vozidiel, ochranné fólie, značenie a montáže pre firmy, flotily a technické tímy.
				</p>
				<div class="hero-actions">
					<a class="button" href="/kontakt/?typ=material">Dopyt na materiály</a>
					<a class="button-secondary" href="/kontakt/?typ=realizacia">Dopyt na realizáciu</a>
				</div>
			</div>

			<div class="hero-specs" aria-label="Kľúčové zameranie CLG">
				<div>
					<span>01</span>
					<strong>Avery print / wrap</strong>
					<p>Materiály pre branding, flotily, retail a aplikácie s nárokmi na životnosť.</p>
				</div>
				<div>
					<span>02</span>
					<strong>3M technické produkty</strong>
					<p>Štítky, lepidlá, funkčné fólie a materiály pre B2B prevádzky.</p>
				</div>
				<div>
					<span>03</span>
					<strong>Montáž a aplikácia</strong>
					<p>Polepy vozidiel, značenie, car wrap, autofólie a fólie na budovy.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="shell proof-strip" aria-label="Dôveryhodnosť">
		{settings.trustBadges.map((badge) => <span>{badge}</span>)}
	</section>

	<section class="shell intro-system">
		<div class="section-intro">
			<p class="eyebrow">Firemný partner, nie iba montážna dielňa</p>
			<h2>Materiál, technické odporúčanie a realizácia v jednom procese.</h2>
			<p>
				Súčasný obsah z carolline.sk sme preložili do B2B jazyka: bezpečnosť, reklama, ochrana, komfort a
				technické riešenia pre vozidlá, budovy a priemysel. Web má jasne ukázať, že CLG vie dodať materiál aj
				prevziať zodpovednosť za výsledok.
			</p>
		</div>
		<div class="system-grid">
			<article>
				<span class="kicker">Distribúcia</span>
				<h3>Fólie a technické produkty</h3>
				<ul class="bullet-list">
					<li>Avery Dennison fólie pre tlač, wrap a solárne aplikácie.</li>
					<li>3M štítky, lepidlá a technické riešenia podľa podkladu a prevádzky.</li>
					<li>Podpora pri výbere materiálu pre opakované B2B zadania.</li>
				</ul>
			</article>
			<article>
				<span class="kicker">Realizácia</span>
				<h3>Polepy, značenie a montáž</h3>
				<ul class="bullet-list">
					<li>Reklamné polepy, fleet branding a car wrap.</li>
					<li>Reflexné a výstražné značenie vrátane riešení podľa EHK 104.</li>
					<li>Autofólie, ochrana laku a fólie na budovy pre komfort aj bezpečnosť.</li>
				</ul>
			</article>
		</div>
	</section>

	<section class="media-band">
		<div class="shell media-grid">
			<img src={workshopImage} alt="Profesionálna aplikácia fólie v dielni CLG" loading="lazy" />
			<img src={fleetImage} alt="Reklamný polep vozidla pre firemnú prezentáciu" loading="lazy" />
			<img src={filmImage} alt="Aplikácia solárnej autofólie" loading="lazy" />
		</div>
	</section>

	<section class="shell product-section">
		<div class="section-header">
			<div>
				<p class="eyebrow">Katalóg + dopyt</p>
				<h2>Produktové línie pre B2B klientov</h2>
			</div>
			<p>
				Bez e-shopového šumu. Každá línia vysvetľuje použitie, obchodný prínos a dôvod, prečo má klient riešiť
				materiál aj aplikáciu cez CLG.
			</p>
		</div>
		<div class="technical-list">
			{
				productLines.map((line, index) => (
					<article>
						<span>{String(index + 1).padStart(2, '0')}</span>
						<div>
							<h3>{line.data.title}</h3>
							<p>{line.data.description}</p>
						</div>
						<ul>
							{line.data.useCases.slice(0, 3).map((item) => <li>{item}</li>)}
						</ul>
						<a href="/folie-materialy/">Detail</a>
					</article>
				))
			}
		</div>
	</section>

	<section class="shell services-section">
		<div class="section-header">
			<div>
				<p class="eyebrow">Realizačné služby</p>
				<h2>Služby pre vozidlá, flotily a prevádzky</h2>
			</div>
			<p>
				Zachovávame pôvodné silné témy webu: bezpečnosť, reklamu, ochranu laku a komfort. Každá služba má
				vlastnú URL a jasné CTA na dopyt.
			</p>
		</div>
		<div class="service-grid">
			{
				services.map((service) => (
					<a class="service-item" href={`/${service.data.slug}/`}>
						<img src={service.data.heroImage} alt={service.data.title} loading="lazy" />
						<div>
							<span>{service.data.shortTitle ?? service.data.title}</span>
							<h3>{service.data.title}</h3>
							<p>{service.data.description}</p>
						</div>
					</a>
				))
			}
		</div>
	</section>

	<section class="shell brand-section">
		<div class="brand-copy">
			<p class="eyebrow">Značky a zodpovednosť</p>
			<h2>Silné značky nestačia. Rozhoduje správne použitie.</h2>
			<p>
				3M a Avery Dennison majú zmysel vtedy, keď klient vie, ktorý materiál patrí na ktorý podklad, akú má mať
				životnosť a ako sa bude aplikovať. Preto je CLG nastavené ako obchodný aj realizačný partner.
			</p>
		</div>
		<div class="brand-grid">
			{
				brands.map((brand) => (
					<a href={`/znacky/${brand.data.slug}/`}>
						<span>{brand.data.logoLabel}</span>
						<strong>{brand.data.title}</strong>
						<p>{brand.data.description}</p>
					</a>
				))
			}
		</div>
	</section>

	<section class="shell references-section">
		<div class="section-header">
			<div>
				<p class="eyebrow">Realizácie</p>
				<h2>Práca, ktorá má držať v prevádzke</h2>
			</div>
			<a class="button-secondary" href="/realizacie/">Všetky realizácie</a>
		</div>
		<div class="reference-grid">
			{
				references.map((reference) => (
					<article>
						<img src={reference.data.image} alt={reference.data.title} loading="lazy" />
						<div>
							<span>{reference.data.category}</span>
							<h3>{reference.data.title}</h3>
							<p>{reference.data.description}</p>
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="shell final-cta">
		<div>
			<p class="eyebrow">Dopyt a konzultácia</p>
			<h2>Pošlite zadanie. Navrhneme materiál, postup alebo realizáciu.</h2>
		</div>
		<div class="final-actions">
			<a class="button" href="/kontakt/?typ=material">Potrebujem materiál</a>
			<a class="button-secondary" href="/kontakt/?typ=realizacia">Potrebujem realizáciu</a>
		</div>
	</section>
</MainLayout>

<style>
	.landing-hero {
		min-height: 660px;
		display: flex;
		align-items: end;
		padding: 5rem 0 2rem;
		background:
			linear-gradient(90deg, rgba(5, 7, 10, 0.94) 0%, rgba(5, 7, 10, 0.72) 48%, rgba(5, 7, 10, 0.2) 100%),
			linear-gradient(180deg, rgba(5, 7, 10, 0.16), #05070a 100%),
			var(--hero-image) center / cover;
	}
	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 360px;
		gap: 2rem;
		align-items: end;
	}
	.hero-copy {
		max-width: 720px;
	}
	.hero-copy h1 {
		margin-bottom: 0.75rem;
		font-size: 5.2rem;
		line-height: 0.9;
	}
	.hero-subtitle {
		max-width: 620px;
		color: var(--color-text);
		font-family: var(--font-heading);
		font-size: 2rem;
		font-style: italic;
		font-weight: 700;
		line-height: 1.1;
		text-transform: uppercase;
	}
	.hero-lead {
		max-width: 620px;
		margin-top: 1.25rem;
		color: var(--color-muted-strong);
		font-size: 1rem;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.5rem;
	}
	.hero-specs {
		display: grid;
		gap: 1px;
		background: rgba(255, 255, 255, 0.12);
		border: 1px solid rgba(255, 255, 255, 0.12);
	}
	.hero-specs div {
		padding: 1rem;
		background: rgba(8, 11, 15, 0.82);
		backdrop-filter: blur(14px);
	}
	.hero-specs span,
	.kicker,
	.technical-list span,
	.service-item span,
	.brand-grid span,
	.reference-grid span {
		display: block;
		color: var(--color-accent);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}
	.hero-specs strong {
		display: block;
		margin: 0.25rem 0;
		color: var(--color-text);
		font-size: 1rem;
	}
	.hero-specs p {
		font-size: 0.88rem;
	}
	.proof-strip {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		margin-top: -1rem;
		border: 1px solid var(--color-border);
		background: var(--color-panel);
	}
	.proof-strip span {
		padding: 1rem;
		border-right: 1px solid var(--color-border);
		color: var(--color-muted-strong);
		font-size: 0.86rem;
		font-weight: 700;
		text-align: center;
	}
	.proof-strip span:last-child {
		border-right: 0;
	}
	.intro-system,
	.product-section,
	.services-section,
	.brand-section,
	.references-section {
		padding-top: 2.25rem;
	}
	.section-header {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.55fr);
		gap: 2rem;
		align-items: end;
		margin-bottom: 1.5rem;
	}
	.section-header > p {
		font-size: 0.96rem;
	}
	.system-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1px;
		background: var(--color-border);
		border: 1px solid var(--color-border);
	}
	.system-grid article {
		padding: 1.5rem;
		background: rgba(18, 24, 32, 0.74);
	}
	.system-grid h3 {
		margin: 0.4rem 0 1rem;
	}
	.media-band {
		padding: 1rem 0;
		background: rgba(255, 255, 255, 0.03);
		border-block: 1px solid var(--color-border);
	}
	.media-grid {
		display: grid;
		grid-template-columns: 1.2fr 0.9fr 0.9fr;
		gap: 0.75rem;
	}
	.media-grid img {
		width: 100%;
		height: 280px;
		object-fit: cover;
	}
	.technical-list {
		display: grid;
		border-top: 1px solid var(--color-border);
	}
	.technical-list article {
		display: grid;
		grid-template-columns: 56px minmax(0, 1fr) minmax(220px, 0.75fr) 72px;
		gap: 1rem;
		align-items: start;
		padding: 1.15rem 0;
		border-bottom: 1px solid var(--color-border);
	}
	.technical-list h3 {
		margin-bottom: 0.35rem;
	}
	.technical-list ul {
		margin: 0;
		padding-left: 1rem;
		color: var(--color-muted);
		font-size: 0.9rem;
	}
	.technical-list a {
		color: var(--color-text);
		font-size: 0.88rem;
		font-weight: 800;
		text-align: right;
		text-decoration: none;
	}
	.service-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		background: var(--color-border);
		border: 1px solid var(--color-border);
	}
	.service-item {
		display: grid;
		grid-template-rows: 170px 1fr;
		color: inherit;
		text-decoration: none;
		background: #0c1117;
	}
	.service-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(0.85);
	}
	.service-item div {
		padding: 1rem;
	}
	.service-item h3 {
		margin: 0.35rem 0 0.55rem;
	}
	.service-item p {
		font-size: 0.9rem;
	}
	.brand-section {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
		gap: 2rem;
		align-items: start;
	}
	.brand-copy p:last-child {
		margin-top: 1rem;
	}
	.brand-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1px;
		background: var(--color-border);
		border: 1px solid var(--color-border);
	}
	.brand-grid a {
		display: grid;
		gap: 0.6rem;
		padding: 1.25rem;
		background: var(--color-panel);
		color: inherit;
		text-decoration: none;
	}
	.brand-grid strong {
		font-size: 1.1rem;
	}
	.reference-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.reference-grid article {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--color-border);
	}
	.reference-grid img {
		width: 100%;
		height: 190px;
		object-fit: cover;
	}
	.reference-grid div {
		padding: 1rem;
	}
	.reference-grid h3 {
		margin: 0.35rem 0 0.55rem;
	}
	.final-cta {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		align-items: center;
		padding: 2rem;
		background: linear-gradient(90deg, rgba(0, 183, 225, 0.12), rgba(255, 255, 255, 0.04));
		border: 1px solid var(--color-border);
	}
	.final-cta h2 {
		max-width: 680px;
	}
	.final-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		justify-content: flex-end;
	}
	@media (max-width: 980px) {
		.landing-hero {
			min-height: auto;
			padding-top: 4rem;
		}
		.hero-inner,
		.section-header,
		.brand-section {
			grid-template-columns: 1fr;
		}
		.hero-copy h1 {
			font-size: 4rem;
		}
		.hero-subtitle {
			font-size: 1.55rem;
		}
		.proof-strip,
		.system-grid,
		.media-grid,
		.service-grid,
		.reference-grid {
			grid-template-columns: 1fr 1fr;
		}
		.technical-list article {
			grid-template-columns: 44px 1fr;
		}
		.technical-list ul,
		.technical-list a {
			grid-column: 2;
			text-align: left;
		}
		.final-cta {
			display: grid;
		}
		.final-actions {
			justify-content: flex-start;
		}
	}
	@media (max-width: 640px) {
		.landing-hero {
			padding-bottom: 1rem;
			background-position: center;
		}
		.hero-copy h1 {
			font-size: 3.1rem;
		}
		.hero-subtitle {
			font-size: 1.28rem;
		}
		.proof-strip,
		.system-grid,
		.media-grid,
		.service-grid,
		.brand-grid,
		.reference-grid {
			grid-template-columns: 1fr;
		}
		.media-grid img {
			height: 220px;
		}
		.final-cta {
			padding: 1.2rem;
		}
	}
</style>
