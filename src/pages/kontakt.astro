---
import { getEntry, render } from 'astro:content';
import ContactForm from '../components/ContactForm.astro';
import PageHero from '../components/PageHero.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_URL } from '../consts';
import { buildBreadcrumbJsonLd, getSiteSettings } from '../lib/content';

const page = await getEntry('pages', 'kontakt');
const settings = await getSiteSettings();

if (!page) {
	throw new Error('Missing page content for kontakt.');
}

const { Content } = await render(page);
const typeParam = Astro.url.searchParams.get('typ');
const variant = typeParam === 'material' || typeParam === 'realizacia' ? typeParam : 'vseobecny';

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'ContactPage',
		name: 'Kontakt | CLG',
		url: `${SITE_URL}/kontakt/`,
	},
	buildBreadcrumbJsonLd([
		{ name: 'Domov', item: SITE_URL },
		{ name: 'Kontakt', item: `${SITE_URL}/kontakt/` },
	]),
];
---

<MainLayout title={page.data.seoTitle ?? page.data.title} description={page.data.description} structuredData={structuredData}>
	<PageHero eyebrow={page.data.heroEyebrow} title={page.data.title} lead={page.data.heroLead} highlights={page.data.highlights} />

	<section class="shell contact-grid">
		<div class="surface contact-copy">
			<Content />
			<div class="details-grid">
				<article>
					<h3>Kontakt</h3>
					<p><a href={`tel:${settings.company.phone.replaceAll(' ', '')}`}>{settings.company.phone}</a></p>
					<p><a href={`mailto:${settings.company.email}`}>{settings.company.email}</a></p>
					<p>{settings.company.workingHours}</p>
				</article>
				<article>
					<h3>Prevádzka</h3>
					<p>{settings.company.primaryAddress.label}</p>
					<p>{settings.company.primaryAddress.street}</p>
					<p>{settings.company.primaryAddress.postalCode} {settings.company.primaryAddress.city}</p>
				</article>
				<article>
					<h3>Sídlo</h3>
					<p>{settings.company.secondaryAddress.street}</p>
					<p>{settings.company.secondaryAddress.postalCode} {settings.company.secondaryAddress.city}</p>
					<p>IČO: {settings.company.ico}</p>
				</article>
			</div>
		</div>
		<ContactForm variant={variant} />
	</section>
</MainLayout>

<style>
	.contact-grid {
		display: grid;
		grid-template-columns: 0.95fr 1.05fr;
		gap: 1.2rem;
	}
	.contact-copy {
		display: grid;
		gap: 1.2rem;
	}
	.contact-copy :global(p) + :global(p) {
		margin-top: 0.9rem;
	}
	.details-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.details-grid article {
		padding-top: 1rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}
	.details-grid h3 {
		margin-bottom: 0.75rem;
	}
	.details-grid a {
		color: var(--color-text);
	}
	@media (max-width: 960px) {
		.contact-grid,
		.details-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
