---
import type { CollectionEntry } from 'astro:content';

interface Props {
	settings: CollectionEntry<'settings'>['data'];
}

const { settings } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="shell">
	<div class="footer-grid">
		<div>
			<p class="eyebrow">B2B partner pre fólie a technické produkty</p>
			<h2>{settings.company.tradingName}</h2>
			<p class="footer-copy">
				Dodávame materiály, navrhujeme riešenia a realizujeme polepy, montáže a technické aplikácie pre
				firmy, fleet zákazníkov a partnerov na Slovensku aj v Česku.
			</p>
		</div>
		<div>
			<h3>Kontakt</h3>
			<ul class="footer-list">
				<li><a href={`tel:${settings.company.phone.replaceAll(' ', '')}`}>{settings.company.phone}</a></li>
				<li><a href={`mailto:${settings.company.email}`}>{settings.company.email}</a></li>
				<li>{settings.company.workingHours}</li>
			</ul>
		</div>
		<div>
			<h3>Prevádzka</h3>
			<ul class="footer-list">
				<li>{settings.company.primaryAddress.label}</li>
				<li>{settings.company.primaryAddress.street}</li>
				<li>
					{settings.company.primaryAddress.postalCode} {settings.company.primaryAddress.city}
				</li>
			</ul>
		</div>
		<div>
			<h3>Firemné údaje</h3>
			<ul class="footer-list">
				<li>IČO: {settings.company.ico}</li>
				<li>DIČ: {settings.company.dic}</li>
				<li>IČ DPH: {settings.company.icDph}</li>
			</ul>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {year} {settings.company.name}. Všetky práva vyhradené.</p>
		<p>Sídlo: {settings.company.secondaryAddress.street}, {settings.company.secondaryAddress.postalCode} {settings.company.secondaryAddress.city}</p>
	</div>
</footer>

<style>
	footer {
		padding-block: 4rem 2.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}
	.footer-grid {
		display: grid;
		gap: 2rem;
		grid-template-columns: 1.35fr repeat(3, minmax(0, 1fr));
	}
	h2,
	h3 {
		margin-bottom: 0.85rem;
	}
	.footer-copy,
	.footer-bottom,
	.footer-list {
		color: var(--color-muted);
	}
	.footer-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.45rem;
	}
	.footer-list a {
		color: var(--color-text);
		text-decoration: none;
	}
	.footer-bottom {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.5rem;
		margin-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		font-size: 0.94rem;
	}
	@media (max-width: 960px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}
		.footer-bottom {
			flex-direction: column;
		}
	}
	@media (max-width: 640px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
