---
import type { CollectionEntry } from 'astro:content';
import LogoMark from './LogoMark.astro';

interface Props {
	navigation: CollectionEntry<'settings'>['data']['navigation'];
}

const { navigation } = Astro.props;
---

<header>
	<nav class="shell">
		<a class="brand" href="/" aria-label="CLG domov">
			<LogoMark />
			<span>Carol line Group</span>
		</a>
		<div class="internal-links">
			{
				navigation.map((item) => (
					<a href={item.href} class={Astro.url.pathname === item.href ? 'active' : undefined}>
						{item.label}
					</a>
				))
			}
		</div>
		<a class="nav-cta" href="/kontakt/?typ=vseobecny">Poslať dopyt</a>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(18px);
		background: rgba(10, 12, 15, 0.78);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		min-height: 5rem;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		font-family: var(--font-heading);
		font-style: italic;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-text);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.internal-links a {
		padding: 0.5rem 0.75rem;
		color: var(--color-muted);
		font-size: 0.94rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		text-decoration: none;
		transition: color 160ms ease;
	}
	.internal-links a:hover,
	.internal-links a.active {
		color: var(--color-text);
	}
	.nav-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.25rem;
		border-radius: 999px;
		background: linear-gradient(135deg, var(--color-accent), #63cff0);
		color: var(--color-ink);
		font-size: 0.92rem;
		font-weight: 800;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		text-decoration: none;
	}
	.nav-cta:hover {
		filter: brightness(1.05);
	}
	@media (max-width: 980px) {
		.internal-links {
			display: none;
		}
	}
	@media (max-width: 640px) {
		.brand span {
			display: none;
		}
		.nav-cta {
			padding-inline: 1rem;
			font-size: 0.84rem;
		}
	}
</style>
